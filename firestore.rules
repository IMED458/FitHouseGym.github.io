// ═══════════════════════════════════════════════════════════════════════════
// FitHouse Gym — Firestore Security Rules
//
// ⚠️  ᲛᲘᲛᲓᲘᲜᲐᲠᲔ ᲛᲓᲒᲝᲛᲐᲠᲔᲝᲑᲐ — ᲬᲐᲘᲙᲘᲗᲮᲔ
//
// პროექტი Firebase Auth-ს არ იყენებს: ადმინის, ოპერატორის, ტრენერისა და
// წევრის ავტორიზაცია ბრაუზერშივე მოწმდება Firestore-იდან წაკითხულ hash-ებზე.
// ამის გამო `request.auth` ყოველთვის null-ია და როლებზე დაფუძნებული დაცვა
// rules-ის დონეზე შეუძლებელია.
//
// ამ ფაილის ამოცანა ამიტომ შეზღუდულია: დაიცვას ის, რაც ბრაუზერს საერთოდ
// არ სჭირდება — კერძოდ `payments`.
//
// ᲠᲐ ᲠᲩᲔᲑᲐ ᲓᲐᲣᲪᲕᲔᲚᲘ (იხ. README / ანგარიში):
//   • users — ადმინის პაროლის hash-ები საჯაროდ იკითხება (login-ს სჭირდება)
//   • members — წევრს შეუძლია საკუთარი აბონემენტის ველების პირდაპირ ჩაწერა
//   ამის სრული გამოსწორება მოითხოვს Firebase Auth-ზე მიგრაციას.
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── payments (Flitt) — ᲑᲠᲐᲣᲖᲔᲠᲘᲓᲐᲜ ᲡᲠᲣᲚᲘᲐᲓ ᲓᲐᲮᲣᲠᲣᲚᲘ ────────────────
    //
    // აქ ფული ფიქსირდება. ბრაუზერს არც კითხვის და არც წერის უფლება არ აქვს.
    // ყველა ოპერაცია გადის Cloudflare Worker-ზე, რომელიც service account-ით
    // წერს და ამ წესებს გვერდს უვლის.
    //
    // მომხმარებელი თავის სტატუსს იღებს ავტორიზებული endpoint-ით:
    //   GET /payments/{uuid}/status
    //
    // ამის გარეშე ნებისმიერს შეეძლებოდა ჩაეწერა status:'paid' და უფასოდ
    // გაეაქტიურებინა აბონემენტი.

    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // ─── აპლიკაციის დანარჩენი კოლექციები ──────────────────────────────────
    //
    // ⚠️ დროებით ღიაა — ზუსტად ისე, როგორც აქამდე მუშაობდა.
    // აქ შევიწროება Firebase Auth-ის გარეშე აპლიკაციას გატეხავს.

    match /members/{doc}            { allow read, write: if true; }
    match /users/{doc}              { allow read, write: if true; }
    match /trainers/{doc}           { allow read, write: if true; }
    match /training_sessions/{doc}  { allow read, write: if true; }
    match /trainer_payments/{doc}   { allow read, write: if true; }
    match /transactions/{doc}       { allow read, write: if true; }
    match /check_ins/{doc}          { allow read, write: if true; }
    match /gym_settings/{doc}       { allow read, write: if true; }
    match /activity_logs/{doc}      { allow read, write: if true; }
    match /member_date_history/{doc}{ allow read, write: if true; }
    match /products/{doc}           { allow read, write: if true; }
    match /subscription_plans/{doc} { allow read, write: if true; }

    // ─── ყველა სხვა — DENY ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
