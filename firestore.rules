// ═══════════════════════════════════════════════════════════════════════════
// FitHouse Gym — Firestore Security Rules
// Firebase Console → Firestore Database → Rules → გადააკოპირე
//
// ⚠️  ამ ფაილში 2 ვარიანტია:
//
// [A] ᲐᲮᲚᲐᲕᲔ ᲡᲐᲛᲣᲨᲐᲝ — Firebase Auth-ის გარეშე
//     მოქმედებს ახლა. request.auth ყოველთვის null-ია, ამიტომ
//     RBAC-ი მხოლოდ data-validation დონეზეა (write validations).
//     trainer_payments-ის სრული დაცვა შეუძლებელია Auth-ის გარეშე.
//
// [B] სათანადო წესები — Firebase Auth + Custom Claims-ით
//     RBAC-ი სრულ სიმძლავრეზე. auth.token.role-ით.
//     საჭიროა: Firebase Auth sign-in + Cloud Function custom claims.
//
// ════════════════════════════════════════════════════════════════════════════
// აირჩიე [A] ან [B] და გადააკოპირე Firebase Console-ში.
// ════════════════════════════════════════════════════════════════════════════

// ════════════════════════════════════════════════════════════════════════════
// [A] ᲐᲮᲚᲐᲕᲔ ᲡᲐᲛᲣᲨᲐᲝ — Firebase Auth-ის გარეშე
// ════════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function notTooLarge(maxFields) {
      return request.resource.data.size() <= maxFields;
    }

    function isValidString(field) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].size() < 512;
    }

    // ─── members ──────────────────────────────────────────────────────────
    // Read: ყველა (QR check-in, member portal, admin)
    // Write: სტრუქტურის ვალიდაცია

    match /members/{memberId} {
      allow read: if true;

      allow create: if hasRequiredFields(['firstName', 'lastName', 'email', 'personalId', 'status'])
        && isValidString('firstName')
        && isValidString('lastName')
        && isValidString('email')
        && isValidString('personalId')
        && request.resource.data.status in ['active', 'expired', 'paused']
        && notTooLarge(40);

      allow update: if request.resource.data.keys().hasAny([
          'firstName','lastName','email','phone','personalId','status',
          'subscriptionType','subscriptionPrice','subscriptionStartDate',
          'subscriptionEndDate','remainingVisits','totalVisits','lastVisit',
          'trainerId','trainerServiceEnabled','note','expiringEmailSent','updatedAt'
        ])
        && notTooLarge(40);

      allow delete: if true;  // admin-only UI-ს მხარეს — Auth-ის გარეშე ვერ ვზღუდავთ
    }

    // ─── users (admin / operator accounts) ───────────────────────────────
    // Read: საჭიროა login-ისთვის (browser-იდან hash-ს ამოწმებს)
    // Write: სტრუქტურის ვალიდაცია

    match /users/{userId} {
      allow read: if true;  // ⚠️ hash-ები ჩანს — Auth-ით გაუმჯობესდება

      allow create: if hasRequiredFields(['username','passwordHash','role','status'])
        && isValidString('username')
        && isValidString('passwordHash')
        && request.resource.data.role in ['admin', 'operator']
        && request.resource.data.status in ['active', 'disabled']
        && notTooLarge(20);

      allow update: if request.resource.data.keys().hasAny([
          'firstName','lastName','username','passwordHash','role','status','updatedAt','isSystemDefault'
        ])
        && notTooLarge(20);

      allow delete: if true;
    }

    // ─── trainers ─────────────────────────────────────────────────────────
    // Read: საჭიროა login-ისთვის და კლიენტის dropdown-ისთვის
    // Write: სტრუქტურის ვალიდაცია

    match /trainers/{trainerId} {
      allow read: if true;

      allow create: if hasRequiredFields(['username','passwordHash','firstName','lastName','status','role'])
        && isValidString('username')
        && isValidString('passwordHash')
        && request.resource.data.role == 'trainer'
        && request.resource.data.status in ['active', 'disabled']
        && notTooLarge(20);

      allow update: if request.resource.data.keys().hasAny([
          'firstName','lastName','phone','specialization','username','passwordHash',
          'photoUrl','status','updatedAt'
        ])
        && notTooLarge(20);

      allow delete: if true;
    }

    // ─── training_sessions ────────────────────────────────────────────────
    // Read: trainer + client (trainerId / clientId check-ი შეუძლებელია Auth-ის გარეშე)
    // Write: სტრუქტურის ვალიდაცია

    match /training_sessions/{sessionId} {
      allow read: if true;

      allow create: if hasRequiredFields(['trainerId','clientId','sessionDate','startTime'])
        && isValidString('trainerId')
        && isValidString('clientId')
        && isValidString('sessionDate')
        && notTooLarge(20);

      allow update: if notTooLarge(20);
      allow delete: if true;
    }

    // ─── trainer_payments ─────────────────────────────────────────────────
    // ⚠️  Auth-ის გარეშე ვერ ვზღუდავთ admin-ის წვდომას Firestore დონეზე!
    //     ადმინი UI-ში ამ collection-ს არ ითხოვს (კოდი არ წერია),
    //     მაგრამ Firestore Console-იდან ან სხვა კლიენტიდან ნახვა შეიძლება.
    //     სრული დაცვა → [B] ვარიანტი Firebase Auth-ით.

    match /trainer_payments/{paymentId} {
      allow read: if true;  // ← Auth-ით: მხოლოდ trainer + client (იხ. [B])

      allow create: if hasRequiredFields(['trainerId','clientId','amount','paymentMonth','status'])
        && isValidString('trainerId')
        && isValidString('clientId')
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status in ['paid', 'unpaid']
        && notTooLarge(20);

      allow update: if notTooLarge(20);
      allow delete: if true;
    }

    // ─── transactions ─────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if true;

      allow create: if hasRequiredFields(['memberId','amount','type','createdAt'])
        && request.resource.data.amount is number
        && notTooLarge(30);

      allow update: if notTooLarge(30);
      allow delete: if true;
    }

    // ─── check_ins ────────────────────────────────────────────────────────
    match /check_ins/{checkInId} {
      allow read: if true;

      allow create: if hasRequiredFields(['memberId','result','checkInTime'])
        && request.resource.data.result in ['approved', 'denied', 'rejected']
        && notTooLarge(20);

      allow update, delete: if false;  // ლოგი შეუცვლელია
    }

    // ─── gym_settings ─────────────────────────────────────────────────────
    match /gym_settings/{docId} {
      allow read: if true;
      allow write: if true;  // Auth-ით: მხოლოდ admin (იხ. [B])
    }

    // ─── activity_logs ────────────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read: if true;
      allow create: if notTooLarge(20);
      allow update, delete: if false;  // ლოგი შეუცვლელია
    }

    // ─── member_date_history ──────────────────────────────────────────────
    match /member_date_history/{docId} {
      allow read: if true;
      allow create: if notTooLarge(20);
      allow update, delete: if false;
    }

    // ─── ყველა სხვა collection-ი — DENY ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


// ════════════════════════════════════════════════════════════════════════════
// [B] სათანადო წესები — Firebase Auth + Custom Claims
//
// მიგრაციისთვის საჭიროა:
//
// 1. Firebase Console → Authentication → Sign-in method → Email/Password ჩართე
//    (ან Anonymous sign-in, ან Custom Token — ნებისმიერი მეთოდი)
//
// 2. Cloud Function-ი Custom Claims-ის დასაყენებლად (Node.js მაგალითი):
//
//    exports.setRole = functions.firestore
//      .document('users/{userId}').onWrite(async (change, context) => {
//        const data = change.after.data();
//        if (!data) return;
//        const uid = data.firebaseUid; // member/trainer/user doc-ში ინახება
//        await admin.auth().setCustomUserClaims(uid, {
//          role: data.role,          // 'admin' | 'operator' | 'trainer' | 'member'
//          ownerId: context.params.userId
//        });
//      });
//
// 3. App-ში login-ის შემდეგ Firebase Auth-ში შეხვედი:
//    signInWithEmailAndPassword(auth, email, password) — ან custom token-ით
//    შემდეგ Firestore-ის request.auth ივსება ავტომატურად.
//
// ════════════════════════════════════════════════════════════════════════════

