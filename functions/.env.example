# ─────────────────────────────────────────────────────────────────────────────
# Flitt payment integration — STAGE 1 (TEST ONLY)
#
# Copy to functions/.env and fill in. NEVER commit the real .env.
# Every value here is server-side only and must never reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Feature flag. When false the pay button disappears and the checkout endpoint
# returns a clean "disabled" response. Everything else keeps working.
FLITT_ENABLED=true

# "test" or "production". Stage 1 is test-only: the app refuses to start in test
# mode with anything other than the sandbox merchant/secret, and refuses to start
# in production mode with sandbox credentials.
FLITT_MODE=test

FLITT_API_BASE_URL=https://pay.flitt.com

# Flitt's documented sandbox merchant. Do not replace while FLITT_MODE=test.
FLITT_MERCHANT_ID=1549901
FLITT_SECRET_KEY=test

FLITT_CURRENCY=GEL
FLITT_LANGUAGE=ka

# Must all be public HTTPS URLs. FLITT_CALLBACK_URL must be reachable from the
# internet — Flitt POSTs to it server-to-server.
# Cloud Functions URLs look like:
#   https://<region>-<project>.cloudfunctions.net/api
#   https://<region>-<project>.cloudfunctions.net/flittCallback
FLITT_RESPONSE_URL=https://fithouse.imed.com.ge/member/payment-result.html
FLITT_CALLBACK_URL=https://us-central1-fit-house-gym-d3595.cloudfunctions.net/flittCallback
FLITT_CANCEL_URL=https://fithouse.imed.com.ge/member/payment-cancel.html

FLITT_HTTP_TIMEOUT_MS=20000

# Stage-1 rollout allowlist (comma separated, lowercase). Only these members see
# the pay button and may create a checkout. Empty => nobody.
FLITT_ALLOWED_EMAILS=imedashviligio27@gmail.com

# HMAC key for member session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_min_16_chars

# Shared secret for the admin-only reconciliation callable.
ADMIN_API_KEY=CHANGE_ME
